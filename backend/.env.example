# ============================================================
# MAPPING NEXUS - Backend Environment Variables
# Copy to .env for local development, or add these in Render.
# ============================================================

# --- Database (REQUIRED) ---
DATABASE_URL=postgresql://user:password@host:5432/mappingnexus?sslmode=require

# --- Authentication (REQUIRED) ---
JWT_SECRET=replace-with-a-long-random-secret

# --- AI Matching Engine (REQUIRED for matching features) ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# --- Redis (OPTIONAL for background embedding jobs) ---
# Leave blank to disable background embedding queue startup.
# Use an Upstash or Render Redis instance when enabling workers.
REDIS_URL=

# --- Encryption (REQUIRED) ---
# Must be a unique 64-character hex string (32 bytes).
# Never use the development sentinel
# deadbeefcafebabedeadbeefcafebabedeadbeefcafebabedeadbeefcafebabe
# outside local development. Generate a production key with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEK=replace-with-64-hex-characters

# --- Server ---
NODE_ENV=development
PORT=3001

# --- Frontend Origin / Password Reset Redirect ---
# Production example: https://your-frontend.vercel.app
FRONTEND_URL=

# Optional comma-separated CORS allowlist.
# Production example: https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# --- Email ---
# In development, the app can run without SMTP configured.
# In production, set these to send onboarding and reset emails.
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@mappingnexus.com
