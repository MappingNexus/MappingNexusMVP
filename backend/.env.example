# ============================================================
# MAPPING NEXUS — Environment Variables
# Copy to .env and fill in all values
# ============================================================

# --- Supabase (REQUIRED) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# IMPORTANT: In Supabase Dashboard > Settings > API, restrict the service role
# key to allowlisted IPs only (your backend server IP). Never expose in frontend.

# --- OpenRouter (REQUIRED for matching engine) ---
# Free tier: google/gemini-2.5-flash-preview:free
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# --- Encryption (REQUIRED) ---
# 64-character hex string (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEK=

# --- Server ---
NODE_ENV=development
PORT=3001

# --- Frontend Origin / Password Reset Redirect (REQUIRED in production) ---
# Set this in Railway to the URL of your deployed frontend (no trailing slash).
# Example: https://your-site.netlify.app
FRONTEND_URL=

# --- Email (REQUIRED for production) ---
# In development, only delivery metadata is logged to console.
# In production, configure SMTP for onboarding emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mappingnexus.com
