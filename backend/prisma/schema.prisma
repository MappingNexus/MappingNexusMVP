// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String?
  subscriptionStatus String    @default("Expired") // Active, Expired
  accessLevel        String    @default("Standard") // Standard, VIP, Admin
  lastPaymentDate    DateTime?
  expiryDate         DateTime?
  monthlySpend       Float     @default(0)
  isRevenueCounted   Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  employees Employee[]

  @@index([email])
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  pin       String
  createdAt DateTime @default(now())

  @@index([email])
}

model Employee {
  id           String   @id @default(uuid())
  name         String
  role         String
  salary       Float?
  userId       String
  
  // Rich Profile Data
  status       String   @default("Active") // Active, On Mission, Travel, On Leave
  efficiency   Int      @default(100)
  location     String   @default("Remote")
  skills       String[] // PostgreSQL supports string arrays
  travelReady  Boolean  @default(true)
  pastMissions String?  // Text description
  education    String?  // Text description

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
}

model Task {
  id             String   @id @default(uuid())
  name           String
  completionDate DateTime
  employeeId     String
  createdAt      DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model Revenue {
  id            String   @id @default(uuid())
  amount        Float
  date          DateTime @default(now())
  payerEmail    String
  approvedBy    String?
  status        String   @default("Completed") // Completed, Pending, Failed
  transactionId String?
  createdAt     DateTime @default(now())

  @@index([payerEmail])
  @@index([date])
}
